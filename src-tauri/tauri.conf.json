{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "faro-app",
  "version": "0.1.1",
  "identifier": "com.stefano.faro-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "faro-app",
        "width": 160,
        "height": 90,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false,
        "resizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/stefff94/faro/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3ODgxRkNCQjE1OTc3MjgKUldRb2QxbXh5eCtJWjhWNWRzaTg2OGpLM3Y1Z2J1MFdqb0o2Y2owWS9kS1IrK1ZSeUhJOE42U20K"
    }
  }
}